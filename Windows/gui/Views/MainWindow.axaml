<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:JackBridge.GUI.ViewModels"
        xmlns:views="using:JackBridge.GUI.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="650"
        x:Class="JackBridge.GUI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{Binding Title}"
        Icon="/Assets/logo.ico"
        Width="1100" Height="650"
        MinWidth="900" MinHeight="600"
        Background="#FF1C1C1E"
        TransparencyLevelHint="AcrylicBlur"
        ExtendClientAreaToDecorationsHint="True">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.DataTemplates>
        <DataTemplate DataType="{x:Type vm:HomeViewModel}">
            <views:HomeView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ConnectionsViewModel}">
            <views:ConnectionsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ActivityViewModel}">
            <views:ActivityView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ProxySettingsViewModel}">
            <views:ProxySettingsWindow/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ProxyRulesViewModel}">
            <views:ProxyRulesWindow/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:AboutViewModel}">
            <views:AboutWindow/>
        </DataTemplate>
    </Window.DataTemplates>

    <Window.Styles>
        <Style Selector="Window">
            <Setter Property="Background" Value="#FF1C1C1E"/>
        </Style>
        <Style Selector="TextBox">
            <Setter Property="Background" Value="#FF1E1E1E"/>
            <Setter Property="Foreground" Value="#FFD4D4D4"/>
            <Setter Property="BorderBrush" Value="#FF3F3F46"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="FontFamily" Value="Consolas,Courier New"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
            <Setter Property="BorderBrush" Value="#FF007ACC"/>
        </Style>
        <Style Selector="Button">
            <Setter Property="Background" Value="#FF0E639C"/>
            <Setter Property="Foreground" Value="#FFFFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#FF1177BB"/>
        </Style>
        <Style Selector="Button.secondary">
            <Setter Property="Background" Value="#FF3E3E42"/>
        </Style>
        <Style Selector="Button.secondary:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#FF505050"/>
        </Style>
        <Style Selector="ComboBox">
            <Setter Property="Background" Value="#FF3C3C3C"/>
            <Setter Property="Foreground" Value="#FFD4D4D4"/>
            <Setter Property="BorderBrush" Value="#FF3F3F46"/>
            <Setter Property="Padding" Value="8"/>
        </Style>
        <Style Selector="TextBlock">
            <Setter Property="Foreground" Value="#FFD4D4D4"/>
        </Style>
        <Style Selector="TextBlock.label">
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style Selector="TextBlock.secondary">
            <Setter Property="Foreground" Value="#FF9E9E9E"/>
        </Style>
        <Style Selector="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style Selector="CheckBox">
            <Setter Property="Foreground" Value="#FFD4D4D4"/>
        </Style>

        <!-- Title bar window button styles -->
        <Style Selector="Button.titleBarButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Foreground" Value="#FFD4D4D4"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style Selector="Button.titleBarButton:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#FF3E3E42"/>
        </Style>
        <Style Selector="Button.titleBarClose:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#FFE81123"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="32,*,28">
        <!-- ═══ Title Bar ═══ -->
        <Border Grid.Row="0"
                Background="#FF1C1C1E"
                BorderBrush="#FF2D2D30"
                BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <!-- App icon + name -->
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            Spacing="8"
                            VerticalAlignment="Center"
                            Margin="12,0,0,0">
                    <Image Source="/Assets/logo.ico" Width="16" Height="16"/>
                    <TextBlock Text="JackBridge"
                               Foreground="#FFE0E0E0"
                               FontSize="12"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <Border Background="#FF0E639C"
                            CornerRadius="3"
                            Padding="4,1"
                            VerticalAlignment="Center">
                        <TextBlock Text="v2.1"
                                   Foreground="#FFFFFFFF"
                                   FontSize="9"
                                   FontWeight="SemiBold"/>
                    </Border>
                </StackPanel>

                <!-- Drag region -->
                <Border Grid.Column="1" Background="Transparent"
                        PointerPressed="OnTitleBarPointerPressed"/>

                <!-- Window controls -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Classes="titleBarButton" Content="—" Click="OnMinimizeClick"/>
                    <Button Classes="titleBarButton" Content="□" Click="OnMaximizeClick"/>
                    <Button Classes="titleBarButton titleBarClose" Content="✕" Click="OnCloseClick"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ Body: Sidebar + Content ═══ -->
        <Grid Grid.Row="1" ColumnDefinitions="220,*">
            <!-- Sidebar -->
            <Border Grid.Column="0"
                    Background="#FF18181A"
                    BorderBrush="#FF2D2D30"
                    BorderThickness="0,0,1,0">
                <DockPanel>
                    <!-- Nav items -->
                    <StackPanel DockPanel.Dock="Top" Margin="0,8,0,0" Spacing="2">
                        <Button Classes="titleBarButton"
                                Content="Dashboard"
                                Command="{Binding NavigateHomeCommand}"
                                Padding="16,10"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"/>
                        <TextBlock Text="Views"
                                   Foreground="#FF656565"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Margin="16,12,0,4"/>
                        <Button Classes="titleBarButton"
                                Content="Connections"
                                Command="{Binding NavigateConnectionsCommand}"
                                Padding="16,10"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"/>
                        <Button Classes="titleBarButton"
                                Content="Activity"
                                Command="{Binding NavigateActivityCommand}"
                                Padding="16,10"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"/>
                        <TextBlock Text="Configuration"
                                   Foreground="#FF656565"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Margin="16,12,0,4"/>
                        <Button Classes="titleBarButton"
                                Content="Rules"
                                Command="{Binding ShowProxyRulesCommand}"
                                Padding="16,10"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"/>
                        <Button Classes="titleBarButton"
                                Content="Settings"
                                Command="{Binding ShowProxySettingsCommand}"
                                Padding="16,10"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"/>
                        <Button Classes="titleBarButton"
                                Content="About"
                                Command="{Binding ShowAboutCommand}"
                                Padding="16,10"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"/>
                    </StackPanel>

                    <!-- Bottom: proxy toggle + preferences + version -->
                    <StackPanel DockPanel.Dock="Bottom" Margin="12,0,12,12" Spacing="8">
                        <Border Background="#FF202022"
                                BorderBrush="#FF353538"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="12">
                            <StackPanel Spacing="8">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Border Width="8" Height="8"
                                            CornerRadius="4"
                                            Background="{Binding HomeVm.ProxyStatusColor}"
                                            VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding HomeVm.ProxyStatusText}"
                                               FontSize="12"
                                               FontWeight="SemiBold"/>
                                </StackPanel>
                                <CheckBox IsChecked="{Binding IsProxyEnabled, Mode=TwoWay}"
                                          Content="Proxy Enabled"
                                          FontSize="12"/>
                            </StackPanel>
                        </Border>

                        <!-- Preferences flyout -->
                        <Button Classes="titleBarButton"
                                Padding="14,8"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="&#x2699;" FontSize="14"/>
                                <TextBlock Text="Preferences" FontSize="12" Foreground="#FF9E9E9E"/>
                            </StackPanel>
                            <Button.Flyout>
                                <MenuFlyout>
                                    <MenuItem Header="Traffic Logging"
                                              Command="{Binding ToggleTrafficLoggingCommand}">
                                        <MenuItem.Icon>
                                            <CheckBox IsChecked="{Binding IsTrafficLoggingEnabled}"
                                                      IsHitTestVisible="False"/>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Header="DNS via Proxy"
                                              Command="{Binding ToggleDnsViaProxyCommand}">
                                        <MenuItem.Icon>
                                            <CheckBox IsChecked="{Binding DnsViaProxy}"
                                                      IsHitTestVisible="False"/>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Header="Localhost via Proxy"
                                              Command="{Binding ToggleLocalhostViaProxyCommand}">
                                        <MenuItem.Icon>
                                            <CheckBox IsChecked="{Binding LocalhostViaProxy}"
                                                      IsHitTestVisible="False"/>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <Separator/>
                                    <MenuItem Header="Close to Tray"
                                              Command="{Binding ToggleCloseToTrayCommand}">
                                        <MenuItem.Icon>
                                            <CheckBox IsChecked="{Binding CloseToTray}"
                                                      IsHitTestVisible="False"/>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Header="Run at Startup"
                                              Command="{Binding ToggleStartWithWindowsCommand}">
                                        <MenuItem.Icon>
                                            <CheckBox IsChecked="{Binding StartWithWindows}"
                                                      IsHitTestVisible="False"/>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <Separator/>
                                    <MenuItem Header="English" Click="OnChangeLanguageEnglish">
                                        <MenuItem.Icon>
                                            <TextBlock Text="{Binding EnglishCheckmark}" FontSize="14"/>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Header="中文 (Chinese)" Click="OnChangeLanguageChinese">
                                        <MenuItem.Icon>
                                            <TextBlock Text="{Binding ChineseCheckmark}" FontSize="14"/>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                </MenuFlyout>
                            </Button.Flyout>
                        </Button>

                        <TextBlock Text="JackBridge v2.1 Beta"
                                   Foreground="#FF656565"
                                   FontSize="10"
                                   TextAlignment="Center"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Content Area -->
            <Border Grid.Column="1" Background="#FF1E1E1E">
                <ContentControl Content="{Binding ActiveView}"
                                HorizontalContentAlignment="Stretch"
                                VerticalContentAlignment="Stretch"/>
            </Border>
        </Grid>

        <!-- ═══ Status Bar ═══ -->
        <Border Grid.Row="2"
                Background="#FF18181A"
                BorderBrush="#FF2D2D30"
                BorderThickness="0,1,0,0"
                Padding="12,0">
            <StackPanel Orientation="Horizontal"
                        Spacing="16"
                        VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <Border Width="6" Height="6"
                            CornerRadius="3"
                            Background="{Binding HomeVm.ProxyStatusColor}"
                            VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding HomeVm.ProxyStatusText}"
                               FontSize="11"
                               Foreground="#FF9E9E9E"/>
                </StackPanel>
                <TextBlock Text="{Binding HomeVm.ActiveRulesCount}"
                           FontSize="11"
                           Foreground="#FF656565"/>
                <TextBlock Text="{Binding HomeVm.EngineType}"
                           FontSize="11"
                           Foreground="#FF656565"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
