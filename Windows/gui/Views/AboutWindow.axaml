<UserControl xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:JackBridge.GUI.ViewModels"
        x:Class="JackBridge.GUI.Views.AboutWindow"
        x:DataType="vm:AboutViewModel"
        x:CompileBindings="True"
        Background="#FF1E1E1E">

    <Design.DataContext>
        <vm:AboutViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*">
        <!-- Header -->
        <Border Grid.Row="0" Background="#FF252526" BorderBrush="#FF007ACC" BorderThickness="0,0,0,1" Padding="20,16">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <Image Source="/Assets/logo.ico"
                       Width="28"
                       Height="28"
                       VerticalAlignment="Center"/>
                <TextBlock Text="About JackBridge"
                           FontSize="18"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Content -->
        <StackPanel Grid.Row="1" Margin="32,24" Spacing="16">
            <Image Source="/Assets/logo.ico"
                   Width="72"
                   Height="72"
                   HorizontalAlignment="Center"/>

            <TextBlock Text="JackBridge"
                       FontSize="28"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Foreground="#FF007ACC"/>

            <TextBlock Text="{Binding Version}"
                       FontSize="14"
                       HorizontalAlignment="Center"
                       Foreground="#FFB0B0B0"/>

            <TextBlock Text="Universal proxy client for Windows applications"
                       FontSize="14"
                       HorizontalAlignment="Center"
                       Foreground="#FFB0B0B0"
                       TextWrapping="Wrap"
                       Margin="0,0,0,8"/>

            <TextBlock Text="Based on: ProxyBridge, improved by Jack Wang"
                       FontSize="13"
                       HorizontalAlignment="Center"
                       Foreground="#FFB0B0B0"
                       Margin="0,4,0,0"/>

            <TextBlock Text="License: MIT"
                       FontSize="13"
                       HorizontalAlignment="Center"
                       Foreground="#FFB0B0B0"
                       Margin="0,8,0,0"/>
        </StackPanel>
    </Grid>
</UserControl>
