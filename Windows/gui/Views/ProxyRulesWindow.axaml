<UserControl xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:JackBridge.GUI.ViewModels"
        xmlns:views="using:JackBridge.GUI.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="700" d:DesignHeight="550"
        x:Name="RulesRoot"
        x:Class="JackBridge.GUI.Views.ProxyRulesWindow"
        x:DataType="vm:ProxyRulesViewModel"
        x:CompileBindings="True"
        Background="#FF1d1d1f"
        HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch">

    <UserControl.Resources>
        <views:SelectAllTextConverter x:Key="SelectAllTextConverter"/>
        <views:SelectAllIconConverter x:Key="SelectAllIconConverter"/>
        <DataTemplate x:Key="RuleRowTemplate" DataType="{x:Type vm:ProxyRule}">
            <Border Background="#FF272729"
                    CornerRadius="10"
                    Margin="0,0,0,2"
                    Padding="16,14"
                    HorizontalAlignment="Stretch"
                    PointerPressed="Rule_PointerPressed"
                    DragDrop.AllowDrop="True">
                <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto"
                      RowDefinitions="Auto,Auto"
                      ColumnSpacing="14" RowSpacing="4">
                    <!-- Row 0: checkbox | index | name | enabled label | actions -->
                    <CheckBox Grid.Row="0" Grid.Column="0"
                              IsChecked="{Binding IsSelected}"
                              VerticalAlignment="Center"/>
                    <Border Grid.Row="0" Grid.Column="1"
                            Background="#FF1d1d1f"
                            CornerRadius="4"
                            Width="36" Height="24"
                            VerticalAlignment="Center">
                        <TextBlock Text="{Binding SectionIndex}"
                                   FontSize="13" FontWeight="600"
                                   Foreground="#FF7a7a7a"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Grid.Row="0" Grid.Column="2"
                               Text="{Binding ProcessName}"
                               FontSize="14" FontWeight="600"
                               Foreground="#FFFFFFFF"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center"/>
                    <StackPanel Grid.Row="0" Grid.Column="3"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                Margin="0,0,16,0">
                        <TextBlock Text="Enabled"
                                   FontSize="9"
                                   Foreground="#FF656565"
                                   HorizontalAlignment="Center"/>
                        <CheckBox IsChecked="{Binding IsEnabled}"
                                  HorizontalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Grid.Row="0" Grid.Column="4"
                                Orientation="Horizontal"
                                Spacing="6"
                                VerticalAlignment="Center">
                        <Button Content="Up"
                                Command="{Binding $parent[ItemsControl].((vm:ProxyRulesViewModel)DataContext).MoveRuleUpCommand}"
                                CommandParameter="{Binding}"
                                Padding="8,4" FontSize="11"
                                Background="#FF2a2a2c"
                                Foreground="#FF7a7a7a"
                                CornerRadius="6"/>
                        <Button Content="Down"
                                Command="{Binding $parent[ItemsControl].((vm:ProxyRulesViewModel)DataContext).MoveRuleDownCommand}"
                                CommandParameter="{Binding}"
                                Padding="8,4" FontSize="11"
                                Background="#FF2a2a2c"
                                Foreground="#FF7a7a7a"
                                CornerRadius="6"/>
                        <Button Content="Edit"
                                Command="{Binding $parent[ItemsControl].((vm:ProxyRulesViewModel)DataContext).EditRuleCommand}"
                                CommandParameter="{Binding}"
                                Padding="8,4" FontSize="11"
                                Background="#FF2a2a2c"
                                Foreground="#FF7a7a7a"
                                CornerRadius="6"/>
                        <Button Content="Del"
                                Command="{Binding $parent[ItemsControl].((vm:ProxyRulesViewModel)DataContext).DeleteRuleCommand}"
                                CommandParameter="{Binding}"
                                Padding="8,4" FontSize="11"
                                Background="#FF2a2a2c"
                                Foreground="#FFE81123"
                                CornerRadius="6"/>
                    </StackPanel>
                    <!-- Row 1: empty | empty | host + port + protocol + action tags -->
                    <StackPanel Grid.Row="1" Grid.Column="2"
                                Grid.ColumnSpan="3"
                                Orientation="Horizontal"
                                Spacing="8">
                        <TextBlock Text="{Binding TargetHosts}"
                                   FontSize="12" Foreground="#FF7a7a7a"/>
                        <TextBlock Text="·" FontSize="12" Foreground="#FF555555"/>
                        <TextBlock Text="{Binding TargetPorts}"
                                   FontSize="12" Foreground="#FF7a7a7a"/>
                        <TextBlock Text="·" FontSize="12" Foreground="#FF555555"/>
                        <TextBlock Text="{Binding Protocol}"
                                   FontSize="12" Foreground="#FF7a7a7a"/>
                        <TextBlock Text="·" FontSize="12" Foreground="#FF555555"/>
                        <Border Background="#1A0066cc"
                                CornerRadius="4"
                                Padding="6,2">
                            <TextBlock Text="{Binding Action}"
                                       FontSize="11" FontWeight="600"
                                       Foreground="#FF0066cc"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <UserControl.Styles>
        <Style Selector="Border.ruleRow.dragging">
            <Setter Property="Opacity" Value="0.55"/>
            <Setter Property="Background" Value="#FF1F3A4A"/>
        </Style>
        <Style Selector="Border.ruleRow.dropTarget">
            <Setter Property="Background" Value="#FF173D32"/>
            <Setter Property="BorderBrush" Value="#FF4EC9B0"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*" HorizontalAlignment="Stretch">
        <!-- Header -->
        <Border Grid.Row="0"
                Background="#FF1d1d1f"
                Padding="32,28,32,20"
                BorderBrush="#FF2d2d30"
                BorderThickness="0,0,0,1"
                HorizontalAlignment="Stretch">
            <Grid ColumnDefinitions="*,Auto"
                  HorizontalAlignment="Stretch">
                <StackPanel Spacing="4">
                    <TextBlock Text="Process Rules"
                               FontSize="21"
                               FontWeight="600"
                               Foreground="#FFFFFFFF"/>
                    <TextBlock Text="Priority order — top rules are handled first"
                               FontSize="13"
                               Foreground="#FF7a7a7a"/>
                </StackPanel>
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="8"
                            VerticalAlignment="Center"
                            IsVisible="{Binding !IsAddRuleViewOpen}">
                    <Button Content="Select All"
                            Command="{Binding ToggleSelectAllCommand}"
                            Background="Transparent"
                            Foreground="#FF0066cc"
                            FontSize="12"
                            Padding="12,6"
                            CornerRadius="9999"
                            IsEnabled="{Binding ProxyRules.Count}"/>
                    <Button Content="Export"
                            Command="{Binding ExportRulesCommand}"
                            Background="Transparent"
                            Foreground="#FF0066cc"
                            FontSize="12"
                            Padding="12,6"
                            CornerRadius="9999"
                            IsEnabled="{Binding HasSelectedRules}"/>
                    <Button Content="Import"
                            Command="{Binding ImportRulesCommand}"
                            Background="Transparent"
                            Foreground="#FF0066cc"
                            FontSize="12"
                            Padding="12,6"
                            CornerRadius="9999"/>
                    <Button Content="Delete"
                            Command="{Binding DeleteSelectedRulesCommand}"
                            Background="Transparent"
                            Foreground="#FFE81123"
                            FontSize="12"
                            Padding="12,6"
                            CornerRadius="9999"
                            IsEnabled="{Binding HasSelectedRules}"/>
                    <Button Content="Add Rule"
                            Command="{Binding AddRuleCommand}"
                            Padding="16,8"
                            FontSize="13"
                            CornerRadius="9999"
                            Margin="8,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Rules List -->
        <Grid Grid.Row="1"
              IsVisible="{Binding !IsAddRuleViewOpen}"
              Background="#FF1d1d1f"
              HorizontalAlignment="Stretch">
            <ScrollViewer Background="Transparent"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalAlignment="Stretch"
                          HorizontalContentAlignment="Stretch">
                <StackPanel Margin="32,20,32,32" Spacing="24">
                    <!-- Active rules section -->
                    <StackPanel Spacing="10">
                        <TextBlock Text="Active rules"
                                   FontSize="12"
                                   FontWeight="600"
                                   Foreground="#FF0066cc"
                                   Margin="4,0,0,0"/>
                        <ItemsControl ItemsSource="{Binding ActiveRules}"
                                      ItemTemplate="{StaticResource RuleRowTemplate}"
                                      x:Name="ActiveRulesItemsControl">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Vertical"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.Styles>
                                <Style Selector="ContentPresenter">
                                    <Setter Property="HorizontalAlignment" Value="Stretch"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                </Style>
                            </ItemsControl.Styles>
                        </ItemsControl>
                        <TextBlock Text="No active rules"
                                   FontSize="13"
                                   Foreground="#FF656565"
                                   Margin="4,12,0,0"
                                   IsVisible="{Binding !HasActiveRules}"/>
                    </StackPanel>

                    <!-- Static rules section -->
                    <StackPanel Spacing="10">
                        <TextBlock Text="Static rules"
                                   FontSize="12"
                                   FontWeight="600"
                                   Foreground="#FF7a7a7a"
                                   Margin="4,0,0,0"/>
                        <ItemsControl ItemsSource="{Binding StaticRules}"
                                      ItemTemplate="{StaticResource RuleRowTemplate}"
                                      x:Name="StaticRulesItemsControl">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Vertical"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.Styles>
                                <Style Selector="ContentPresenter">
                                    <Setter Property="HorizontalAlignment" Value="Stretch"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                </Style>
                            </ItemsControl.Styles>
                        </ItemsControl>
                        <TextBlock Text="No static rules"
                                   FontSize="13"
                                   Foreground="#FF656565"
                                   Margin="4,12,0,0"
                                   IsVisible="{Binding !HasStaticRules}"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Add Rule Form -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      IsVisible="{Binding IsAddRuleViewOpen}"
                      HorizontalAlignment="Stretch">
            <StackPanel Margin="32,24" Spacing="16"
                        MaxWidth="560">
                <TextBlock Text="New Rule"
                           FontSize="21"
                           FontWeight="600"
                           Foreground="#FFFFFFFF"/>

                <StackPanel Spacing="6">
                    <TextBlock Text="{Binding Loc.ApplicationsLabel}"
                               FontSize="13"
                               Foreground="#FF7a7a7a"/>
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBox Grid.Column="0"
                                 Text="{Binding NewProcessName}"
                                 Watermark="Any"
                                 Margin="0,0,8,0"/>
                        <Button Grid.Column="1"
                                Content="{Binding Loc.BrowseButton}"
                                Command="{Binding BrowseProcessCommand}"
                                Padding="12,8"
                                MinWidth="100"
                                Background="#FF2a2a2c"
                                Foreground="#FFFFFFFF"
                                CornerRadius="8"/>
                    </Grid>
                    <ComboBox ItemsSource="{Binding RunningProcesses}"
                              SelectedItem="{Binding SelectedProcessChoice}"
                              HorizontalAlignment="Stretch"
                              PlaceholderText="Choose a running process">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayName}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>

                <StackPanel Spacing="6">
                    <TextBlock Text="Rule section"
                               FontSize="13"
                               Foreground="#FF7a7a7a"/>
                    <ComboBox SelectedIndex="{Binding NewRuleSectionIndex}"
                              HorizontalAlignment="Stretch">
                        <ComboBoxItem Content="Active - prioritized app-specific rules"/>
                        <ComboBoxItem Content="Static - always-on fallback rules"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel Spacing="6">
                    <TextBlock Text="{Binding Loc.TargetHostsLabel}"
                               FontSize="13"
                               Foreground="#FF7a7a7a"/>
                    <TextBox Text="{Binding NewTargetHosts}" Watermark="Any"/>
                </StackPanel>

                <StackPanel Spacing="6">
                    <TextBlock Text="{Binding Loc.TargetPortsLabel}"
                               FontSize="13"
                               Foreground="#FF7a7a7a"/>
                    <TextBox Text="{Binding NewTargetPorts}" Watermark="Any"/>
                </StackPanel>

                <StackPanel Spacing="6">
                    <TextBlock Text="{Binding Loc.ProtocolLabel}"
                               FontSize="13"
                               Foreground="#FF7a7a7a"/>
                    <ComboBox HorizontalAlignment="Stretch" x:Name="ProtocolComboBox">
                        <ComboBoxItem Content="{Binding Loc.ProtocolTCP}" Tag="TCP"/>
                        <ComboBoxItem Content="{Binding Loc.ProtocolUDP}" Tag="UDP"/>
                        <ComboBoxItem Content="{Binding Loc.ProtocolBoth}" Tag="BOTH"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel Spacing="6">
                    <TextBlock Text="{Binding Loc.ActionLabel}"
                               FontSize="13"
                               Foreground="#FF7a7a7a"/>
                    <ComboBox HorizontalAlignment="Stretch"
                              x:Name="ActionComboBox"
                              SelectionChanged="ActionComboBox_SelectionChanged">
                        <ComboBoxItem Content="{Binding Loc.ActionProxy}" Tag="PROXY"/>
                        <ComboBoxItem Content="{Binding Loc.ActionDirect}" Tag="DIRECT"/>
                        <ComboBoxItem Content="{Binding Loc.ActionBlock}" Tag="BLOCK"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Spacing="12"
                            Margin="0,12,0,0">
                    <Button Content="{Binding Loc.ButtonCancel}"
                            Command="{Binding CancelAddRuleCommand}"
                            Background="Transparent"
                            Foreground="#FF0066cc"
                            CornerRadius="9999"
                            Width="100"/>
                    <Button Content="{Binding Loc.SaveRuleButton}"
                            Command="{Binding SaveNewRuleCommand}"
                            CornerRadius="9999"
                            Width="130"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
