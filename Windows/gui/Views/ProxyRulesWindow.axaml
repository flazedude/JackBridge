<UserControl xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:JackBridge.GUI.ViewModels"
        xmlns:views="using:JackBridge.GUI.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="700" d:DesignHeight="550"
        x:Name="RulesRoot"
        x:Class="JackBridge.GUI.Views.ProxyRulesWindow"
        x:DataType="vm:ProxyRulesViewModel"
        x:CompileBindings="True"
        Background="#FF1E1E1E">

    <UserControl.Resources>
        <views:SelectAllTextConverter x:Key="SelectAllTextConverter"/>
        <views:SelectAllIconConverter x:Key="SelectAllIconConverter"/>
        <DataTemplate x:Key="RuleRowTemplate" DataType="{x:Type vm:ProxyRule}">
            <Border Classes="ruleRow"
                    Background="#FF232323"
                    BorderBrush="#FF383838"
                    BorderThickness="1"
                    CornerRadius="6"
                    Margin="12,8,12,0"
                    Padding="14,12"
                    PointerPressed="Rule_PointerPressed"
                    DragDrop.AllowDrop="True">
                <Grid ColumnDefinitions="Auto,Auto,*,Auto" ColumnSpacing="12">
                    <CheckBox Grid.Column="0"
                              IsChecked="{Binding IsSelected}"
                              VerticalAlignment="Center"/>
                    <Border Grid.Column="1"
                            Background="#FF1E1E1E"
                            BorderBrush="#FF3F3F46"
                            BorderThickness="1"
                            CornerRadius="4"
                            Width="42"
                            Height="28"
                            VerticalAlignment="Center">
                        <TextBlock Text="{Binding SectionIndex}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="#FFFFFFFF"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="2"
                                Spacing="6"
                                MinWidth="0"
                                VerticalAlignment="Center">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0"
                                       Text="{Binding ProcessName}"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="#FFEDEDED"
                                       TextTrimming="CharacterEllipsis"/>
                            <CheckBox Grid.Column="1"
                                      Content="{Binding $parent[ItemsControl].((vm:ProxyRulesViewModel)DataContext).Loc.EnabledLabel}"
                                      IsChecked="{Binding IsEnabled}"
                                      Foreground="#FFB0B0B0"
                                      Margin="12,0,0,0"/>
                        </Grid>
                        <WrapPanel>
                            <TextBlock Text="{Binding TargetHosts, StringFormat='Host: {0}'}"
                                       FontSize="12"
                                       Foreground="#FFB0B0B0"
                                       Margin="0,0,14,0"/>
                            <TextBlock Text="{Binding TargetPorts, StringFormat='Port: {0}'}"
                                       FontSize="12"
                                       Foreground="#FFB0B0B0"
                                       Margin="0,0,14,0"/>
                            <TextBlock Text="{Binding Protocol, StringFormat='Protocol: {0}'}"
                                       FontSize="12"
                                       Foreground="#FFB0B0B0"
                                       Margin="0,0,14,0"/>
                            <TextBlock Text="{Binding Action}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#FF4EC9B0"
                                       Margin="0,0,14,0"/>
                        </WrapPanel>
                    </StackPanel>
                    <WrapPanel Grid.Column="3"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center">
                        <Button Content="Up"
                                Command="{Binding $parent[ItemsControl].((vm:ProxyRulesViewModel)DataContext).MoveRuleUpCommand}"
                                CommandParameter="{Binding}"
                                Padding="6,4"
                                MinWidth="34"
                                FontSize="12"
                                Margin="0,0,6,6"
                                Classes="secondary"/>
                        <Button Content="Down"
                                Command="{Binding $parent[ItemsControl].((vm:ProxyRulesViewModel)DataContext).MoveRuleDownCommand}"
                                CommandParameter="{Binding}"
                                Padding="6,4"
                                MinWidth="44"
                                FontSize="12"
                                Margin="0,0,6,6"
                                Classes="secondary"/>
                        <Button Content="Edit"
                                Command="{Binding $parent[ItemsControl].((vm:ProxyRulesViewModel)DataContext).EditRuleCommand}"
                                CommandParameter="{Binding}"
                                Padding="6,4"
                                MinWidth="48"
                                Margin="0,0,6,6"
                                FontSize="12"/>
                        <Button Content="Delete"
                                Command="{Binding $parent[ItemsControl].((vm:ProxyRulesViewModel)DataContext).DeleteRuleCommand}"
                                CommandParameter="{Binding}"
                                Padding="6,4"
                                MinWidth="54"
                                FontSize="12"
                                Margin="0,0,0,6"
                                Classes="secondary"/>
                    </WrapPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <UserControl.Styles>
        <Style Selector="Border.ruleRow.dragging">
            <Setter Property="Opacity" Value="0.55"/>
            <Setter Property="Background" Value="#FF1F3A4A"/>
        </Style>

        <Style Selector="Border.ruleRow.dropTarget">
            <Setter Property="Background" Value="#FF173D32"/>
            <Setter Property="BorderBrush" Value="#FF4EC9B0"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </UserControl.Styles>

    <DockPanel Width="{Binding #RulesRoot.Bounds.Width}"
               HorizontalAlignment="Stretch"
               VerticalAlignment="Stretch">
        <!-- Header -->
        <Border DockPanel.Dock="Top" Background="#FF1E1E1E" Padding="20,16">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock Text="Rules" FontSize="13" VerticalAlignment="Center" Foreground="#FFB0B0B0"/>
                    <TextBlock Text="{Binding Loc.ProxyRulesTitle}"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#FFE0E0E0"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="8"
                            IsVisible="{Binding !IsAddRuleViewOpen}">
                    <Button Content="{Binding AllRulesSelected, Converter={StaticResource SelectAllTextConverter}}"
                            Command="{Binding ToggleSelectAllCommand}"
                            Classes="secondary"
                            Padding="12,8"
                            IsEnabled="{Binding ProxyRules.Count}">
                        <Button.Content>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="{Binding AllRulesSelected, Converter={StaticResource SelectAllIconConverter}}" FontSize="14"/>
                                <TextBlock Text="{Binding AllRulesSelected, Converter={StaticResource SelectAllTextConverter}}"/>
                            </StackPanel>
                        </Button.Content>
                    </Button>
                    <Button Command="{Binding DeleteSelectedRulesCommand}"
                            Classes="secondary"
                            Padding="12,8"
                            IsEnabled="{Binding HasSelectedRules}">
                        <TextBlock Text="Delete Selected"/>
                    </Button>
                    <Button Command="{Binding ExportRulesCommand}"
                            Classes="secondary"
                            Padding="12,8"
                            IsEnabled="{Binding HasSelectedRules}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="" FontSize="14"/>
                            <TextBlock Text="Export"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding ImportRulesCommand}"
                            Classes="secondary"
                            Padding="12,8">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="" FontSize="14"/>
                            <TextBlock Text="Import"/>
                        </StackPanel>
                    </Button>
                    <Button Content="{Binding Loc.ButtonAdd}"
                            Command="{Binding AddRuleCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Rules List View -->
        <Grid IsVisible="{Binding !IsAddRuleViewOpen}"
              Width="{Binding #RulesRoot.Bounds.Width}"
              HorizontalAlignment="Stretch"
              Background="#FF1E1E1E">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Rules Header -->
            <Border Grid.Row="0"
                    Background="#FF1E1E1E"
                    BorderBrush="#FF3F3F46"
                    BorderThickness="0,1,0,1"
                    Padding="18,10">
                <TextBlock Text="Priority order: top rules are handled first"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="#FFB0B0B0"
                           VerticalAlignment="Center"/>
            </Border>

            <!-- Table Body -->
            <ScrollViewer Grid.Row="1"
                          Background="#FF1E1E1E"
                          HorizontalAlignment="Stretch"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto">
                <DockPanel LastChildFill="True"
                           Width="{Binding #RulesRoot.Bounds.Width}"
                           HorizontalAlignment="Stretch">
                    <StackPanel DockPanel.Dock="Top"
                                HorizontalAlignment="Stretch">
                        <Border Background="#FF191919"
                                Padding="14,10"
                                BorderBrush="#FF333333"
                                BorderThickness="0,0,0,1">
                            <TextBlock Text="Active rules"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="#FF4EC9B0"/>
                        </Border>
                        <ItemsControl ItemsSource="{Binding ActiveRules}"
                                      HorizontalAlignment="Stretch"
                                      ItemTemplate="{StaticResource RuleRowTemplate}"
                                      x:Name="ActiveRulesItemsControl"/>
                    </StackPanel>

                    <StackPanel DockPanel.Dock="Top"
                                HorizontalAlignment="Stretch">
                        <Border Background="#FF191919"
                                Padding="14,10"
                                BorderBrush="#FF333333"
                                BorderThickness="0,1,0,1">
                            <TextBlock Text="Static rules"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="#FFB0B0B0"/>
                        </Border>
                        <ItemsControl ItemsSource="{Binding StaticRules}"
                                      HorizontalAlignment="Stretch"
                                      ItemTemplate="{StaticResource RuleRowTemplate}"
                                      x:Name="StaticRulesItemsControl"/>
                    </StackPanel>
                    <Border Background="#FF1E1E1E"/>
                </DockPanel>
            </ScrollViewer>
        </Grid>

        <!-- Add Rule Form View -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      IsVisible="{Binding IsAddRuleViewOpen}">
            <StackPanel Margin="24,20"
                        Spacing="20">
                <!-- Applications Section -->
                <StackPanel Spacing="6">
                    <TextBlock Text="{Binding Loc.ApplicationsLabel}" Classes="label"/>
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBox Grid.Column="0"
                                 Text="{Binding NewProcessName}"
                                 Watermark="Any"
                                 Margin="0,0,8,0"/>
                        <Button Grid.Column="1"
                                Content="{Binding Loc.BrowseButton}"
                                Command="{Binding BrowseProcessCommand}"
                                Padding="12,8"
                                MinWidth="100"/>
                    </Grid>
                    <ComboBox ItemsSource="{Binding RunningProcesses}"
                              SelectedItem="{Binding SelectedProcessChoice}"
                              HorizontalAlignment="Stretch"
                              PlaceholderText="Choose a running process">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayName}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <TextBlock Text="{Binding Loc.ExampleApplications}"
                               FontSize="11"
                               Foreground="#FF999999"
                               TextWrapping="Wrap"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Rule Section -->
                <StackPanel Spacing="6">
                    <TextBlock Text="Rule section" Classes="label"/>
                    <ComboBox SelectedIndex="{Binding NewRuleSectionIndex}"
                              HorizontalAlignment="Stretch">
                        <ComboBoxItem Content="Active - prioritized app-specific rules"/>
                        <ComboBoxItem Content="Static - always-on fallback rules"/>
                    </ComboBox>
                </StackPanel>

                <!-- Target Hosts Section -->
                <StackPanel Spacing="6">
                    <TextBlock Text="{Binding Loc.TargetHostsLabel}" Classes="label"/>
                    <TextBox Text="{Binding NewTargetHosts}"
                             Watermark="Any"/>
                    <TextBlock Text="{Binding Loc.ExampleTargetHosts}"
                               FontSize="11"
                               Foreground="#FF999999"
                               TextWrapping="Wrap"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Target Ports Section -->
                <StackPanel Spacing="6">
                    <TextBlock Text="{Binding Loc.TargetPortsLabel}" Classes="label"/>
                    <TextBox Text="{Binding NewTargetPorts}"
                             Watermark="Any"/>
                    <TextBlock Text="{Binding Loc.ExampleTargetPorts}"
                               FontSize="11"
                               Foreground="#FF999999"
                               TextWrapping="Wrap"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Protocol Section -->
                <StackPanel Spacing="6">
                    <TextBlock Text="{Binding Loc.ProtocolLabel}" Classes="label"/>
                    <ComboBox HorizontalAlignment="Stretch"
                              x:Name="ProtocolComboBox">
                        <ComboBoxItem Content="{Binding Loc.ProtocolTCP}" Tag="TCP"/>
                        <ComboBoxItem Content="{Binding Loc.ProtocolUDP}" Tag="UDP"/>
                        <ComboBoxItem Content="{Binding Loc.ProtocolBoth}" Tag="BOTH"/>
                    </ComboBox>
                </StackPanel>

                <!-- Action Section -->
                <StackPanel Spacing="6">
                    <TextBlock Text="{Binding Loc.ActionLabel}" Classes="label"/>
                    <ComboBox HorizontalAlignment="Stretch"
                              x:Name="ActionComboBox"
                              SelectionChanged="ActionComboBox_SelectionChanged">
                        <ComboBoxItem Content="{Binding Loc.ActionProxy}" Tag="PROXY"/>
                        <ComboBoxItem Content="{Binding Loc.ActionDirect}" Tag="DIRECT"/>
                        <ComboBoxItem Content="{Binding Loc.ActionBlock}" Tag="BLOCK"/>
                    </ComboBox>
                </StackPanel>

                <!-- Validation Error -->
                <TextBlock Text="{Binding ProcessNameError}"
                           IsVisible="{Binding ProcessNameError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                           Foreground="#FFFF6B6B"
                           FontSize="12"
                           Margin="0,4,0,0"/>

                <!-- Action Buttons -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Spacing="12"
                            Margin="0,16,0,0">
                    <Button Content="{Binding Loc.ButtonCancel}"
                            Classes="secondary"
                            Command="{Binding CancelAddRuleCommand}"
                            Width="100"/>
                    <Button Content="{Binding Loc.SaveRuleButton}"
                            Command="{Binding SaveNewRuleCommand}"
                            Width="130"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>



